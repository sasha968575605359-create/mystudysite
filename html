<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Study Hub | Dashboard</title>
    <style>
        :root { --bg: #0f172a; --card: #1e293b; --accent: #38bdf8; --text: #f8fafc; --success: #22c55e; }
        body { font-family: 'Segoe UI', sans-serif; background: var(--bg); color: var(--text); padding: 20px; margin: 0; display: flex; flex-direction: column; align-items: center; }
        .container { width: 100%; max-width: 500px; }
        .card { background: var(--card); padding: 20px; border-radius: 15px; border: 1px solid #334155; margin-bottom: 20px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); }
        .accent-border { border: 2px solid var(--accent); text-align: center; }
        .btn { background: var(--accent); color: var(--bg); border: none; padding: 10px 20px; border-radius: 8px; font-weight: bold; cursor: pointer; width: 100%; margin-top: 10px; }
        .btn-outline { background: transparent; border: 1px solid var(--accent); color: var(--accent); }
        .lesson-title { font-size: 1.4rem; color: var(--accent); font-weight: bold; }
        .task-box { border-left: 4px solid var(--accent); padding-left: 15px; margin-top: 15px; }
        table { width: 100%; border-collapse: collapse; margin-top: 10px; font-size: 0.9rem; }
        th, td { padding: 10px; text-align: left; border-bottom: 1px solid #334155; }
        .highlight { background: rgba(56, 189, 248, 0.15); color: var(--accent); font-weight: bold; }
    </style>
</head>
<body>

<div class="container">
    <div class="card accent-border">
        <div id="status-time" style="font-size: 0.8rem; opacity: 0.6; margin-bottom: 5px;"></div>
        <div class="lesson-title" id="current-lesson-name">Загрузка...</div>
        <div id="timer-val" style="margin-top: 5px;"></div>
        <button class="btn btn-outline" id="notif-btn" onclick="requestNotif()">🔔 Включить уведомления</button>
    </div>

    <div class="card">
        <div style="font-weight: bold; margin-bottom: 10px; display: flex; justify-content: space-between;">
            <span>💡 Доп. задание</span>
            <span id="task-subject" style="color: var(--accent); font-size: 0.8rem;"></span>
        </div>
        <div id="task-text" class="task-box">Нажми кнопку ниже, чтобы получить задание для саморазвития.</div>
        <button class="btn" onclick="generateTask()">Получить квест</button>
    </div>

    <div style="margin: 10px 0; font-weight: bold;">📅 Расписание на сегодня:</div>
    <table class="card" style="padding: 0;" id="schedule-table"></table>
</div>

<script>
    const extraTasks = [
        {sub: "Английский", text: "Выучи 5 новых слов на тему 'Технологии'"},
        {sub: "Математика", text: "Реши 3 примера на логику из интернета"},
        {sub: "Общее", text: "Посмотри 10-минутное видео о космосе на YouTube"},
        {sub: "Программирование", text: "Добавь новую кнопку или измени цвет фона на этом сайте"},
        {sub: "Украинский", text: "Прочитай 2 страницы любого произведения вне программы"}
    ];

    const fullSchedule = {
        1: ["Алгебра", "География", "Укр. язык", "Биология", "Укр. язык", "Химия", "Информатика"],
        2: ["Англ", "Геометрия", "Физика", "Укр. язык", "Биология", "Музыка/Рис", "Физра", "Гром. освіта"],
        3: ["Химия", "Основы здоровья", "Укр. лит", "Алгебра", "История Укр", "Англ", "География", "Биология"],
        4: ["Геометрия", "Физика", "Физра", "Всемирка", "Технологии", "Англ"],
        5: ["Физра", "Укр. язык", "Укр. лит", "Алгебра", "Зарубежка", "Информатика", "Немецкий"]
    };

    function getLessonTimes(index) {
        let start = new Date();
        start.setHours(9, 0, 0); 
        start.setMinutes(start.getMinutes() + (index * 35)); // 25 урок + 10 перемена
        let end = new Date(start);
        end.setMinutes(end.getMinutes() + 25);
        return { start, end };
    }

    function requestNotif() {
        Notification.requestPermission().then(perm => {
            if(perm === 'granted') document.getElementById('notif-btn').innerText = "✅ Уведомления активны";
        });
    }

    function generateTask() {
        const random = extraTasks[Math.floor(Math.random() * extraTasks.length)];
        document.getElementById('task-subject').innerText = random.sub;
        document.getElementById('task-text').innerText = random.text;
    }

    let notified = [];

    function update() {
        const now = new Date();
        const day = now.getDay();
        const subjects = fullSchedule[day] || [];
        const table = document.getElementById('schedule-table');
        table.innerHTML = "";

        let currentFound = false;

        subjects.forEach((name, i) => {
            const {start, end} = getLessonTimes(i);
            const row = table.insertRow();
            const timeStr = `${start.toTimeString().slice(0,5)}-${end.toTimeString().slice(0,5)}`;
            
            // Логика уведомлений (за 1 минуту до начала)
            let diff = (start - now) / 1000 / 60;
            if (diff > 0 && diff <= 1 && !notified.includes(name)) {
                new Notification("Скоро урок!", { body: `Через минуту начнется ${name}` });
                notified.push(name);
            }

            if (now >= start && now <= end) {
                row.className = "highlight";
                document.getElementById('current-lesson-name').innerText = name;
                document.getElementById('timer-val').innerText = "Урок идет";
                currentFound = true;
            }
            row.innerHTML = `<td>${timeStr}</td><td>${name}</td>`;
        });

        if (!currentFound) {
            document.getElementById('current-lesson-name').innerText = "Перемена или отдых";
            document.getElementById('timer-val').innerText = "Свободное время";
        }
        document.getElementById('status-time').innerText = now.toLocaleTimeString();
    }

    setInterval(update, 1000);
    update();
</script>
</body>
</html>
