<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Моя Учеба | Dashboard</title>
    <style>
        :root {
            --bg-color: #0f172a;
            --card-bg: #1e293b;
            --accent: #38bdf8;
            --text: #f8fafc;
        }
        body {
            font-family: 'Segoe UI', sans-serif;
            background-color: var(--bg-color);
            color: var(--text);
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 20px;
            margin: 0;
        }
        .container {
            width: 100%;
            max-width: 600px;
        }
        .status-card {
            background: var(--card-bg);
            padding: 20px;
            border-radius: 15px;
            text-align: center;
            border: 2px solid var(--accent);
            margin-bottom: 20px;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        }
        .current-lesson {
            font-size: 1.5rem;
            font-weight: bold;
            color: var(--accent);
        }
        .timer {
            font-size: 1.2rem;
            margin-top: 10px;
        }
        .schedule-table {
            width: 100%;
            background: var(--card-bg);
            border-radius: 10px;
            overflow: hidden;
            border-collapse: collapse;
        }
        .schedule-table th, .schedule-table td {
            padding: 12px;
            text-align: left;
            border-bottom: 1px solid #334155;
        }
        .schedule-table th {
            background: #334155;
            color: var(--accent);
        }
        .today-label {
            margin-bottom: 10px;
            font-size: 1.2rem;
            color: var(--accent);
        }
        .highlight {
            background: rgba(56, 189, 248, 0.2) !important;
        }
    </style>
</head>
<body>

<div class="container">
    <div class="status-card">
        <div id="day-now" style="font-size: 0.9rem; opacity: 0.7;">Загрузка...</div>
        <div class="current-lesson" id="lesson-text">Проверка расписания...</div>
        <div class="timer" id="timer-text">--:--</div>
    </div>

    <div class="today-label">Расписание на сегодня:</div>
    <table class="schedule-table" id="schedule-body">
        </table>
</div>

<script>
    const schedule = {
        1: [ // Понедельник
            {name: "Алгебра", start: "09:00", end: "09:25"},
            {name: "География", start: "09:35", end: "10:00"},
            {name: "Укр. язык", start: "10:10", end: "10:35"},
            {name: "Биология", start: "10:45", end: "11:10"},
            {name: "Укр. язык", start: "11:20", end: "11:45"},
            {name: "Химия", start: "11:55", end: "12:20"},
            {name: "Информатика", start: "12:30", end: "12:55"}
        ],
        2: [ /* Вторник */ ], // Заполнится по аналогии
        3: [ /* Среда */ ],
        // Добавим логику автозаполнения для всех дней ниже
    };

    // Функция для расчета времени (упростим ввод для остальных дней)
    function generateTimes(startTime, count) {
        let times = [];
        let current = new Date(`2026-01-01T${startTime}:00`);
        for(let i=0; i<count; i++) {
            let start = current.toTimeString().slice(0,5);
            current.setMinutes(current.getMinutes() + 25);
            let end = current.toTimeString().slice(0,5);
            times.push({start, end});
            current.setMinutes(current.getMinutes() + 10); // Перемена
        }
        return times;
    }

    const fullSchedule = {
        1: schedule[1],
        2: ["Англ", "Геометрия", "Физика", "Укр. язык", "Биология", "Музыка/Рис", "Физра", "Гром. освіта"].map((n, i) => ({name: n, ...generateTimes("09:00", 8)[i]})),
        3: ["Химия", "Основы здоровья", "Укр. лит", "Алгебра", "История Укр", "Англ", "География", "Биология"].map((n, i) => ({name: n, ...generateTimes("09:00", 8)[i]})),
        4: ["Геометрия", "Физика", "Физра", "Всемирка", "Технологии", "Англ"].map((n, i) => ({name: n, ...generateTimes("09:00", 6)[i]})),
        5: ["Физра", "Укр. язык", "Укр. лит", "Алгебра", "Зарубежка", "Информатика", "Немецкий"].map((n, i) => ({name: n, ...generateTimes("09:00", 7)[i]}))
    };

    function update() {
        const now = new Date();
        const day = now.getDay(); // 1-5
        const timeStr = now.toTimeString().slice(0,5);
        const dayNames = ["Воскресенье", "Понедельник", "Вторник", "Среда", "Четверг", "Пятница", "Суббота"];
        
        document.getElementById('day-now').innerText = dayNames[day] + ", " + timeStr;

        const todaysLessons = fullSchedule[day] || [];
        const table = document.getElementById('schedule-body');
        table.innerHTML = "<tr><th>Время</th><th>Урок</th></tr>";

        let currentFound = false;

        todaysLessons.forEach(lesson => {
            const row = table.insertRow();
            if (timeStr >= lesson.start && timeStr <= lesson.end) {
                row.className = "highlight";
                document.getElementById('lesson-text').innerText = "Сейчас: " + lesson.name;
                currentFound = true;
            }
            row.innerHTML = `<td>${lesson.start}-${lesson.end}</td><td>${lesson.name}</td>`;
        });

        if (!currentFound) {
            document.getElementById('lesson-text').innerText = "Уроков сейчас нет";
            document.getElementById('timer-text').innerText = "Отдыхай!";
        }
    }

    setInterval(update, 1000);
    update();
</script>

</body>
</html>
